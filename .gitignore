/target
/target-alt
.claude/worktrees/
# Hidden per-asset editor sidecar/cache dirs (next to the source files). Both are
# regenerable or per-machine, so they're never committed:
#   .soul-import/ — per-texture import settings (filter/colorspace/wrap sidecars)
#   .soul-cache/  — any asset-local generated cache (e.g. compiled BC7)
# The live BC7 texture cache currently lives in the OS temp dir, not the asset tree.
**/.soul-import/
**/.soul-cache/

# SDF diagnostic log (throwaway dev output)
sdf_diag.log

# Autonomous-loop runtime state (session-only, never committed).
.claude/scheduled_tasks.lock

# Editor's default unsaved-scene placeholder (real scenes are saved with a name,
# e.g. world.scn.ron). Empty scratch file — should never be committed.
assets/scenes/untitled.scene

# Chrome tracing profiler output (editor feature)
trace-*.json

# Editor-side context: persisted dock layout + named layouts (per-machine, never committed).
.soul/

# RenderDoc captures + analysis artifacts: ignore the scratch dir (multi-GB .rdc captures,
# .png/.zip dumps, *_out.txt) BUT keep the reusable analysis toolkit (rdoc/scripts/)
# tracked. Re-include needs the parent dir un-ignored first, hence the !rdoc/scripts line.
rdoc/*
!rdoc/scripts/
rdoc/scripts/**/__pycache__/
*.cap
*.rdc

# Dear ImGui / Nsight overlay config dropped next to the exe during a capture.
imgui.ini
