{
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -c \"[System.Media.SystemSounds]::Asterisk.Play(); Start-Sleep -Milliseconds 600\" 2>/dev/null || true",
            "statusMessage": "Playing notification sound"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -c \"[System.Media.SystemSounds]::Asterisk.Play(); Start-Sleep -Milliseconds 600\" 2>/dev/null || true",
            "statusMessage": "Playing notification sound"
          }
        ]
      }
    ]
  }
}
